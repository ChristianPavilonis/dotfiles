{
  "pollIntervalMinutes": 1440,
  "databasePath": "./data/yesmand-pr-reviews.db",
  "opencode": {
    "url": "http://127.0.0.1:4097",
    "username": "opencode",
    "passwordEnv": "OPENCODE_SERVER_PASSWORD",
    "model": "openai/gpt-5.3-codex"
  },
  "plugins": [
    {
      "id": "github-pr-reviews",
      "module": "./src/plugins/github-pr-reviews/index.ts",
      "enabled": true,
      "config": {
        "reviewRepoPath": "~/projects/stackpop-reviews",
        "lookbackHours": 24,
        "repos": [
          {
            "owner": "IABTechLab",
            "repo": "trusted-server"
          },
          {
            "owner": "stackpop",
            "repo": "mocktioneer"
          },
          {
            "owner": "stackpop",
            "repo": "edgezero"
          }
        ]
      }
    }
  ]
}
