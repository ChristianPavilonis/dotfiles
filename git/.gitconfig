[user]
	email = christianpavilonis@outlook.com
	name = Christian
	# signingkey set via platform-specific includes below
[diff]
    diffFilter = delta --color-only

[pull]
	ff = true
	rebase = false
[core]
	editor = nvim
	fileMode = false
[submodule]
	recurse = true
[init]
	defaultBranch = master
[alias]
	nah = "!f(){ git reset --hard; git clean -df; if [ -d \".git/rebase-apply\" ] || [ -d \".git/rebase-merge\" ]; then git rebase --abort; fi; }; f"
[push]
	autoSetupRemote = true
[rerere]
	enabled = true
[gitbutler]
	aiModelProvider = openai
[gpg]
	format = ssh
	program = /opt/homebrew/bin/gpg
[commit]
	gpgsign = true
[gpg "ssh"]
	# allowedSignersFile set via platform-specific includes below

[includeIf "gitdir:/Users/"]
	path = ~/.gitconfig-platform
[includeIf "gitdir:/home/"]
	path = ~/.gitconfig-platform
